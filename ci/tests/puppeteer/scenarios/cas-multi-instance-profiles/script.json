  "dependencies": "core",
  "properties": [
    "--cas.server.prefix=${cas.server.name}/cas"
  ],
  "instances": 2,
  "instance1": {
    "dependencies": "rest",
    "properties": [
      "--cas.server.name=https://localhost:8443"
    ]
  },
  "instance2": {
    "dependencies": "reports",
